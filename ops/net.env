# CAN-RTOS-Sim Environment Configuration

# CAN Interface
CAN_INTERFACE=vcan0

# Node Configuration
NODE_A_SENSOR_RATE=100
NODE_B_WATCHDOG_TIMEOUT=2000

# Server Configuration
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# Panel Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NODE_ENV=development

# Fault Injection
FAULT_DROP_DURATION=5000
FAULT_DELAY_MS=100
FAULT_FLOOD_RATE=1000
